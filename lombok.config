# 阻止配置向上冒泡（停止向上查找父目录的配置文件）
# 默认情况下，Lombok 会从当前目录向上递归查找所有 lombok.config 文件
# 设置为 true 后，只使用当前目录的配置，不再向上查找
# 场景：确保项目配置不被父目录的配置覆盖
config.stopBubbling = true

# 生成 toString() 方法时调用父类的 toString()
# 配置参数 CALL : 生成 super.toString() + "Field1=xxx, Field2=xxx"
# 配置参数 SKIP : 只输出当前类的字段
lombok.tostring.callsuper=CALL

# 生成 equals() 和 hashCode() 时调用父类的对应方法
# 配置参数 CALL : 比较/计算时包含父类字段
# 配置参数 SKIP : 只比较当前类的字段
lombok.equalsandhashcode.callsuper=CALL

# 生成链式调用的 setter 方法
lombok.accessors.chain=true
